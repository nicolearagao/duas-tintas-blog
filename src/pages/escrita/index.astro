---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft && data.category === 'personal'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title="Escrita — duas tintas" description="Ensaios pessoais e reflexões" currentPath="/escrita">
  <h1 class="page-title">Escrita</h1>
  <p class="page-description">Ensaios pessoais, reflexões e escrita criativa.</p>
  <div class="posts-list">
    {posts.length > 0 ? (
      posts.map(post => <PostCard post={post} />)
    ) : (
      <p class="empty-state">Nenhum post ainda.</p>
    )}
  </div>
</BaseLayout>

<style>
  .page-title {
    margin-bottom: 0.3rem;
    font-size: 1.5rem;
  }

  .page-description {
    color: var(--color-text-muted);
    font-size: 0.9rem;
    margin-bottom: 1.5rem;
  }

  .empty-state {
    color: var(--color-text-muted);
    font-style: italic;
  }
</style>
